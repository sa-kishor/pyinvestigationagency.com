# ============================================================================
# TWILIO CONFIGURATION (WhatsApp Only)
# ============================================================================
# Sign up for Twilio at: https://www.twilio.com/console
# Get your credentials from: https://www.twilio.com/console

# Your Twilio Account SID (find in Twilio Console)
TWILIO_ACCOUNT_SID=your_account_sid_here

# Your Twilio Auth Token (find in Twilio Console)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp Number for WhatsApp messages
# Typically your Twilio phone number with WhatsApp enabled
TWILIO_WHATSAPP_NUMBER=+1234567890

# ============================================================================
# ADMIN PANEL CONFIGURATION
# ============================================================================
# Default admin credentials - CHANGE THESE IMMEDIATELY IN PRODUCTION!
ADMIN_EMAIL=pyinvestigationagency@gmail.com
ADMIN_PASSWORD=Parthi@1992..

